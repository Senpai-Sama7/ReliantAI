# ═══════════════════════════════════════════════════════════════════════
# ReliantAI Platform — Required Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in all values before running
#   docker compose up
#
# Every variable below is REQUIRED. docker compose will refuse to start
# if any are missing (enforced via ${VAR:?error} syntax).
# ═══════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # PostgreSQL superuser password
POSTGRES_DB=reliantai

# HA Mode (optional):
# When running with docker-compose.ha.yml, PgPool-II becomes the database entry
# point. Update each service's DATABASE_URL to use "pgpool" instead of "postgres":
#   DATABASE_URL=postgresql://pgpool:5432/money
#   DATABASE_URL=postgresql://pgpool:5432/complianceone
#   DATABASE_URL=postgresql://pgpool:5432/finops360
#   DATABASE_URL=postgresql://pgpool:5432/integration
# See docs/runbooks/database-ha.md for full failover procedure.
REPMGR_PASSWORD=            # Replication manager password (HA mode only)
PGPOOL_ADMIN_PASSWORD=      # PgPool-II admin password (HA mode only)

# ── Service API Keys ─────────────────────────────────────────────────
DISPATCH_API_KEY=           # Money/dispatch service authentication
COMPLIANCEONE_API_KEY=      # ComplianceOne service authentication
FINOPS360_API_KEY=          # FinOps360 service authentication
ORCHESTRATOR_API_KEY=       # Orchestrator API authentication (also used as API_KEY fallback)
API_KEY=                    # Global fallback API key

# ── External Services ────────────────────────────────────────────────
GEMINI_API_KEY=             # Google Gemini AI API key
TWILIO_SID=                 # Twilio Account SID
TWILIO_TOKEN=               # Twilio Auth Token

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=             # Redis AUTH password (used in REDIS_URL and --requirepass)

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=               # Comma-separated allowed origins (e.g. https://app.reliantai.com,https://admin.reliantai.com)
                            # MUST NOT be * when allow_credentials is True

# ── Alertmanager / Monitoring ─────────────────────────────────────────
ALERTMANAGER_SLACK_URL=     # Slack incoming webhook for alerts
ALERTMANAGER_PAGERDUTY_KEY= # PagerDuty integration key
ALERTMANAGER_SMTP_HOST=localhost:587
ALERTMANAGER_SMTP_FROM=alerts@reliantai.io
ALERTMANAGER_SMTP_USER=alerts@reliantai.io
ALERTMANAGER_SMTP_PASS=
ALERTMANAGER_DEFAULT_EMAIL=team@reliantai.io
ALERTMANAGER_ONCALL_EMAIL=oncall@reliantai.io

# ── Vault ─────────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200

# ── Optional ──────────────────────────────────────────────────────────
# ENV=production            # Runtime environment flag

# ── Frontend (Vite) ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:9000
VITE_WS_URL=ws://localhost:9000

# ── Actuator ───────────────────────────────────────────────────────────
# Set to false to enable live Docker scaling. Default true for safety.
ACTUATOR_DRY_RUN=true

# ── Integration / Event Bus ───────────────────────────────────────────
EVENT_BUS_API_KEY=change-me-event-bus-api-key
JWT_SECRET=change-in-production
AUTH_SERVICE_URL=http://integration:8080

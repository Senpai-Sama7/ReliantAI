## 12. Phase 7: CI/CD Strategy

### Multi-Stack Challenge

ReliantAI uses **Rust, Python (pip + Poetry), Node.js (npm + pnpm), and Bun**. A single CI pipeline must handle all of them.

### GitHub Actions Workflow

```yaml
# .github/workflows/ci.yml
name: ReliantAI CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]

jobs:
  detect-changes:
    runs-on: ubuntu-latest
    outputs:
      bap: ${{ steps.filter.outputs.bap }}
      money: ${{ steps.filter.outputs.money }}
      integration: ${{ steps.filter.outputs.integration }}
      acropolis: ${{ steps.filter.outputs.acropolis }}
      cleardesk: ${{ steps.filter.outputs.cleardesk }}
      nexus: ${{ steps.filter.outputs.nexus }}
    steps:
      - uses: actions/checkout@v4
      - uses: dorny/paths-filter@v3
        id: filter
        with:
          filters: |
            bap: ['B-A-P/**']
            money: ['Money/**']
            integration: ['integration/**']
            acropolis: ['Acropolis/**']
            cleardesk: ['ClearDesk/**']
            nexus: ['soviergn_ai/**']

  test-bap:
    needs: detect-changes
    if: needs.detect-changes.outputs.bap == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: '3.11' }
      - run: pip install poetry && cd B-A-P && poetry install
      - run: cd B-A-P && poetry run pytest tests/ -v --cov=src --cov-report=xml

  test-money:
    needs: detect-changes
    if: needs.detect-changes.outputs.money == 'true'
    runs-on: ubuntu-latest
    services:
      redis:
        image: redis:7-alpine
        ports: ['6379:6379']
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: '3.13' }
      - run: cd Money && pip install -r requirements.txt
      - run: cd Money && ENV=test python3 -m pytest tests/ -v

  test-integration:
    needs: detect-changes
    if: needs.detect-changes.outputs.integration == 'true'
    runs-on: ubuntu-latest
    services:
      redis:
        image: redis:7-alpine
        ports: ['6379:6379']
    env:
      AUTH_SECRET_KEY: test-ci-secret-key-minimum-32-characters-long
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: '3.13' }
      - run: cd integration && pip install -r requirements.txt
      - run: cd integration && pytest tests/ -v

  test-acropolis:
    needs: detect-changes
    if: needs.detect-changes.outputs.acropolis == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
      - run: cd Acropolis && cargo test

  test-cleardesk:
    needs: detect-changes
    if: needs.detect-changes.outputs.cleardesk == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: '20' }
      - run: cd ClearDesk && npm ci && npm test
```

This uses **path-based filtering** so only changed projects run tests, keeping CI fast.


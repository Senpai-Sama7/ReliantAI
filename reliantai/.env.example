# ReliantAI Platform — local / staging environment variables
# Copy to .env and fill in secrets before running the API or Celery workers.

# Database (required)
DATABASE_URL=postgresql://reliantai:reliantai_dev@localhost:5432/reliantai

# Redis (required for cache + Celery)
REDIS_URL=redis://:reliantai_dev@localhost:6379/0

# API authentication (required for protected /api/v2/prospects routes)
API_SECRET_KEY=dev_secret_key_change_in_production

# ISR revalidation (required for site registration → preview cache purge)
REVALIDATE_SECRET=dev_revalidate_secret
PREVIEW_SITES_BASE_URL=https://preview.reliantai.org

# Google AI (required for CrewAI agents)
GOOGLE_AI_API_KEY=

# Twilio SMS (optional — outreach dispatch)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Resend email (optional — outreach dispatch)
RESEND_API_KEY=
FROM_EMAIL=noreply@reliantai.org

# Hot-lead notification (optional)
OWNER_PHONE=

# Connection pool tuning (optional)
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

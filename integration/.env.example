# ReliantAI Integration Platform - Environment Configuration

# ============================================================================
# AUTH SERVICE
# ============================================================================
# Generate a secure key using: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET_KEY=your-secret-key-min-32-chars-change-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_PORT=8080

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# POSTGRESQL
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=reliantai
POSTGRES_PASSWORD=change-in-production
POSTGRES_DB=reliantai_integration
POSTGRES_MAX_CONNECTIONS=20

# ============================================================================
# KAFKA (EVENT BUS)
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RETENTION_HOURS=24
KAFKA_NUM_PARTITIONS=10
KAFKA_REPLICATION_FACTOR=1

# ============================================================================
# API GATEWAY (KONG)
# ============================================================================
KONG_DATABASE=postgres
KONG_PG_HOST=localhost
KONG_PG_PORT=5432
KONG_PG_USER=kong
KONG_PG_PASSWORD=change-in-production
KONG_PG_DATABASE=kong
KONG_ADMIN_LISTEN=0.0.0.0:8001
KONG_PROXY_LISTEN=0.0.0.0:8000, 0.0.0.0:8443 ssl

# ============================================================================
# OBSERVABILITY
# ============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-in-production

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=reliantai-integration

# ============================================================================
# SERVICE MESH (LINKERD)
# ============================================================================
LINKERD_NAMESPACE=linkerd
LINKERD_TRUST_DOMAIN=cluster.local

# ============================================================================
# SAGA ORCHESTRATOR
# ============================================================================
SAGA_PORT=8090
SAGA_TIMEOUT_SECONDS=300
SAGA_MAX_RETRIES=3

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Platform API (public generated-sites endpoint — no auth required)
API_BASE_URL=http://localhost:8000

# Legacy alias (optional)
# PLATFORM_API_URL=http://localhost:8000

# On-demand ISR revalidation — server-only; must match reliantai API REVALIDATE_SECRET
REVALIDATE_SECRET=your_revalidate_secret_here

# Checkout CTAs on the preview banner (/checkout lives on the marketing site).
NEXT_PUBLIC_CHECKOUT_BASE_URL=https://reliantai.org

# Server-side API fetch timeout in milliseconds (default 10000).
API_TIMEOUT_MS=10000

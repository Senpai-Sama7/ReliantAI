# ReliantAI Platform - Production Environment Configuration
# Copy this file to .env for production deployment
# WARNING: Use strong, unique keys and never commit this file

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# Core Service URLs (Internal Docker network)
MONEY_URL=http://money:8000
COMPLIANCEONE_URL=http://complianceone:8001
FINOPS360_URL=http://finops360:8002
ORCHESTRATOR_URL=http://orchestrator:9000
INTEGRATION_URL=http://integration:8080

# Public URLs (for external access)
PUBLIC_MONEY_URL=https://reliantai.io/api/money
PUBLIC_COMPLIANCEONE_URL=https://reliantai.io/api/compliance
PUBLIC_FINOPS360_URL=https://reliantai.io/api/finops
PUBLIC_ORCHESTRATOR_URL=https://reliantai.io/api/orchestrator

# API Keys (Use strong, unique keys for production - 32+ chars)
DISPATCH_API_KEY=prod-dispatch-key-change-me-immediately
COMPLIANCEONE_API_KEY=prod-compliance-key-change-me-immediately
FINOPS360_API_KEY=prod-finops-key-change-me-immediately
ORCHESTRATOR_API_KEY=prod-orchestrator-key-change-me-immediately

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=prod-postgres-password-change-me-immediately-min-32-chars
POSTGRES_DB=reliantai
DATABASE_URL=postgresql://postgres:prod-postgres-password-change-me-immediately-min-32-chars@postgres:5432/reliantai

# Redis
REDIS_URL=redis://redis:6379/0

# External Services (Production credentials)
GEMINI_API_KEY=your-production-gemini-key
TWILIO_SID=your-production-twilio-sid
TWILIO_TOKEN=your-production-twilio-token
STRIPE_SECRET_KEY=sk_live_production_key
STRIPE_WEBHOOK_SECRET=whsec_production_secret

# Security (Use cryptographically secure random values)
SECRET_KEY=prod-secret-key-change-me-immediately-min-64-chars-very-secure
JWT_SECRET=prod-jwt-secret-change-me-immediately-min-64-chars-very-secure
ENCRYPTION_KEY=prod-encryption-key-change-me-immediately-min-32-chars

# SSL/TLS
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# HashiCorp Vault (Secrets Management)
VAULT_ADDR=https://vault.reliantai.io:8200
VAULT_TOKEN=prod-vault-token
VAULT_NAMESPACE=production

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ALERTING_ENABLED=true

# PagerDuty (Alerting)
PAGERDUTY_SERVICE_KEY=prod-pagerduty-key
PAGERDUTY_ENABLED=true

# Backup
S3_BUCKET=production-reliantai-backups
BACKUP_RETENTION_DAYS=30

# Feature Flags
AUTO_SCALING_ENABLED=true
AUTO_HEALING_ENABLED=true
AI_PREDICTIONS_ENABLED=true

# Rate Limiting (Stricter for production)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# CORS (Restrict to production domains only)
CORS_ORIGINS=https://reliantai.io,https://app.reliantai.io

# Logging
LOG_FORMAT=json
LOG_DESTINATION=stdout

# Performance
WORKER_PROCESSES=4
MAX_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# Compliance
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years for compliance
DATA_RETENTION_DAYS=2555

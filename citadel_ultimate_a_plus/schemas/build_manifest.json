{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_slug",
    "build_dir",
    "entrypoint",
    "artifacts",
    "qa_notes",
    "preview_url",
    "lighthouse_estimate",
    "size_bytes",
    "build_sha"
  ],
  "properties": {
    "lead_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]{5,120}$"
    },
    "build_dir": {
      "type": "string",
      "maxLength": 300
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+\\.html$",
      "maxLength": 100
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "maxLength": 200,
        "pattern": "^[a-zA-Z0-9/_.-]+$"
      }
    },
    "qa_notes": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000
    },
    "preview_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "lighthouse_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "performance",
        "accessibility",
        "best_practices",
        "seo"
      ],
      "properties": {
        "performance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "accessibility": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "best_practices": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "seo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "build_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{16,64}$"
    }
  }
}

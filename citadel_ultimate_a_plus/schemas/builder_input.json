{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_slug",
    "business_name",
    "vertical",
    "city",
    "state",
    "brand_voice",
    "primary_offer",
    "primary_cta",
    "phone",
    "email",
    "services",
    "social_proof",
    "design_tokens",
    "seo"
  ],
  "properties": {
    "lead_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]{5,120}$"
    },
    "business_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9\\s&'.,()/-]+$"
    },
    "vertical": {
      "type": "string",
      "minLength": 3,
      "maxLength": 60,
      "pattern": "^[a-z_]+$"
    },
    "city": {
      "type": "string",
      "maxLength": 60,
      "pattern": "^[a-zA-Z\\s'-]+$"
    },
    "state": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "brand_voice": {
      "type": "string",
      "maxLength": 60,
      "pattern": "^[a-z-]+$"
    },
    "primary_offer": {
      "type": "string",
      "minLength": 5,
      "maxLength": 140
    },
    "primary_cta": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60
    },
    "phone": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9\\s()+.-]{10,24}$"
    },
    "email": {
      "type": [
        "string",
        "null"
      ],
      "format": "email",
      "maxLength": 254
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 80,
        "pattern": "^[a-zA-Z0-9\\s&'.,()/-]+$"
      }
    },
    "social_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rating",
        "rating_count",
        "review_snippet"
      ],
      "properties": {
        "rating": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 5
        },
        "rating_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 1000000
        },
        "review_snippet": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "design_tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "accent",
        "bg",
        "text"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "bg": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "text": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        }
      }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 10,
          "maxLength": 160
        },
        "description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 320
        }
      }
    }
  }
}

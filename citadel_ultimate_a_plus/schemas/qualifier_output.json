{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_slug",
    "business_name",
    "vertical",
    "city",
    "state",
    "has_website",
    "website_url",
    "phone",
    "email",
    "has_gbp",
    "web_presence_score",
    "rating",
    "rating_count",
    "opportunity_score",
    "weakness_summary",
    "disqualify_reason",
    "market_establishments",
    "density_weight_applied",
    "source_ref",
    "source_payload"
  ],
  "properties": {
    "lead_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]{5,120}$"
    },
    "business_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9\\s&'.,()/-]+$"
    },
    "vertical": {
      "type": "string",
      "minLength": 3,
      "maxLength": 60,
      "pattern": "^[a-z_]+$"
    },
    "city": {
      "type": "string",
      "maxLength": 60,
      "pattern": "^[a-zA-Z\\s'-]+$"
    },
    "state": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "has_website": {
      "type": "boolean"
    },
    "website_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "phone": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9\\s()+.-]{10,24}$"
    },
    "email": {
      "type": [
        "string",
        "null"
      ],
      "format": "email",
      "maxLength": 254
    },
    "has_gbp": {
      "type": "boolean"
    },
    "web_presence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "rating": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 5
    },
    "rating_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000
    },
    "opportunity_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "weakness_summary": {
      "type": "string",
      "minLength": 5,
      "maxLength": 400
    },
    "disqualify_reason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 300
    },
    "market_establishments": {
      "type": "integer",
      "minimum": 0
    },
    "density_weight_applied": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_ref": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "source_payload": {
      "type": "object"
    }
  }
}

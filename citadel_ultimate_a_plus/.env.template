# Core paths
CITADEL_DB_PATH=workspace/state/lead_queue.db
CITADEL_LOG_PATH=workspace/logs/orchestrator.log
CITADEL_DASHBOARD_HOST=127.0.0.1
CITADEL_DASHBOARD_PORT=8888

# Market / geography defaults (used when a page does not expose city/state)
CITADEL_DEFAULT_CITY=Houston
CITADEL_DEFAULT_STATE=TX

# Dashboard read API protection (optional but recommended)
# If set, supply X-API-Key on /api/* requests (webhook uses HMAC instead)
CITADEL_DASHBOARD_API_KEY=

# Webhook signing (required for /api/webhooks/openclaw)
OPENCLAW_WEBHOOK_SECRET=change-me
OPENCLAW_WEBHOOK_MAX_SKEW_SECONDS=300

# Company identity used in compliance footer + outreach
BRAND_NAME=ReliantAI
BRAND_FROM_NAME=Douglas Mitchell
BRAND_FROM_EMAIL=douglas-d-mitchell@outlook.com
BRAND_POSTAL_ADDRESS=Humble, TX
BRAND_OPTOUT_EMAIL=optout@reliantai.org

# Deployment backend (local_fs is fully functional out-of-the-box)
DEPLOY_BACKEND=local_fs
DEPLOY_ENABLED=true

# Email backend (local_outbox writes .eml files to workspace/outbox; smtp sends live)
EMAIL_BACKEND=local_outbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=douglas-d-mitchell@outlook.com

# Optional Census API key (market ranker still works without one, within public limits)
CENSUS_API_KEY=

# Optional S3 checkpoint sync daemon
STATE_BUCKET=
CITADEL_WORKDIR=workspace

# CORS origins (comma-separated, empty = disabled)
CITADEL_CORS_ORIGINS=

# Structured logging (text or json)
CITADEL_LOG_FORMAT=text

# Rate limiting (requests per minute per IP, 0 = disabled)
CITADEL_RATE_LIMIT_API_RPM=60
CITADEL_RATE_LIMIT_WEBHOOK_RPM=30

# Deep crawling (Phase 1) — Playwright-based multi-page site analysis
CITADEL_CRAWL_MAX_PAGES=20
CITADEL_CRAWL_TIMEOUT_MS=15000

# ML inference (Phase 2) — set to true to use spaCy NER + zero-shot classification
CITADEL_ML_ENABLED=false

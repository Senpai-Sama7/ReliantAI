# ── Twilio ────────────────────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_PHONE=+1xxxxxxxxxx
OWNER_PHONE=+18329477028
TECH_PHONE_NUMBER=+15551234567
COMPOSIO_API_KEY=cmp_xxxxx

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://reliantai:change-in-production@127.0.0.1:5435/reliantai_integration

# ── Security ──────────────────────────────────────────────────
DISPATCH_API_KEY=super-secret-key-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=your-session-secret-here

# ── Sales Intelligence Integration ────────────────────────────
# Shared auth service for bearer-token validation
AUTH_SERVICE_URL=http://localhost:8080

# Event Bus for cross-service notifications
EVENT_BUS_URL=http://localhost:8081
# Bearer token for POST /publish (must match integration event bus service)
EVENT_BUS_API_KEY=change-me-event-bus-api-key
DEFAULT_TENANT_ID=money-default

# HubSpot API Key (for CRM sync)
HUBSPOT_API_KEY=pat-na1-xxxxx

# Google Sheets ID (for logging dispatches)
# Sheet URL: https://docs.google.com/spreadsheets/d/1jdS3oYIOQgHhWZqlza8ThIYknMmYM0TiPLNXXt_t-1Y/edit
GOOGLE_SHEETS_ID=1jdS3oYIOQgHhWZqlza8ThIYknMmYM0TiPLNXXt_t-1Y

# Slack Webhook (for hot lead alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Make.com Webhook Secret (for validating incoming webhooks)
MAKE_WEBHOOK_SECRET=your-webhook-secret

# ── Billing / Stripe ──────────────────────────────────────────
# Stripe API Keys (test mode for development)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Intelligent Storage Nexus — Environment Configuration
# Copy to .env and adjust values as needed.

# Database
ISN_DB_HOST=localhost
ISN_DB_PORT=5433
ISN_DB_NAME=intelligent_storage
ISN_DB_USER=storage_admin
ISN_DB_PASS=CHANGE_ME

# Ollama Embedding Service
ISN_OLLAMA_URL=http://localhost:11434/api/embed
ISN_EMBED_MODEL=nomic-embed-text
ISN_EMBED_DIM=768

# Indexer
ISN_BATCH_SIZE=32
ISN_TEXT_PREVIEW_LEN=500
ISN_MAX_EMBED_TEXT=2000

# Tree of Thoughts
ISN_TOT_MAX_DEPTH=3
ISN_TOT_BRANCHING_FACTOR=3
ISN_TOT_SIMILARITY_THRESHOLD=0.75

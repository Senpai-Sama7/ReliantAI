# ============================================================================
# AI Analytics Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_NAME=AI-Analytics Platform
DEBUG=False
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://analytics:analytics@localhost:5432/analytics
DB_POOL_SIZE=20

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
# Redis connection string
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# IMPORTANT: Generate a strong random secret key for production!
# You can generate one with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
AUTH_SERVICE_URL=http://localhost:8080
EVENT_BUS_URL=http://localhost:8081
DEFAULT_TENANT_ID=bap-default

# ----------------------------------------------------------------------------
# AI/ML Configuration
# ----------------------------------------------------------------------------
# Gemini API key for AI-powered features
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
MAX_TOKENS=2048
TEMPERATURE=0.2

# ----------------------------------------------------------------------------
# ETL Configuration
# ----------------------------------------------------------------------------
MAX_WORKERS=8
BATCH_SIZE=1000
CHUNK_SIZE=10000

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Use * for development only, specify exact origins for production
ALLOWED_ORIGINS=["*"]

# ----------------------------------------------------------------------------
# Production Deployment Notes
# ----------------------------------------------------------------------------
# 1. Always use strong, randomly generated secrets
# 2. Never expose sensitive credentials in logs or error messages
# 3. Use environment-specific values (dev, staging, prod)
# 4. Consider using a secrets manager (AWS Secrets Manager, HashiCorp Vault)
# 5. Rotate secrets regularly
# 6. Use TLS/SSL for all connections in production
# 7. Restrict CORS to specific origins
# 8. Enable all security headers
# 9. Use managed database and cache services
# 10. Monitor and audit all access
# 11. Point AUTH_SERVICE_URL at the shared ReliantAI auth service
# 12. Point EVENT_BUS_URL at the shared ReliantAI event bus

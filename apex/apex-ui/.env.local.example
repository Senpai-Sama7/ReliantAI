# Copy this file to .env.local and fill in values
# .env.local is gitignored — never commit it

# Server-side URL (used by Next.js API routes to reach apex-agents)
# Local dev:  http://localhost:8001
# Docker:     http://apex-agents:8001  (set in docker-compose env)
AGENT_API_URL=http://localhost:8001

# Client-side Langfuse host for trace deep-links
# Shown in the browser — use your self-hosted URL if applicable
NEXT_PUBLIC_LANGFUSE_HOST=https://cloud.langfuse.com

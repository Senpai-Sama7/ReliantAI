# ═════════════════════════════════════════════════════════════════════════
# APEX Environment Variables
# Copy this file to .env and fill in required values.
# NEVER commit .env to git. It is in .gitignore.
# ═════════════════════════════════════════════════════════════════════════


# ── Database ─────────────────────────────────────────────────────────────────────
# REQUIRED. Change before any non-local deployment.
POSTGRES_PASSWORD=changeme

# REQUIRED. Password for the Langfuse postgres instance.
LANGFUSE_DB_PASSWORD=changeme-langfuse


# ── Integration Layer (Event Bus) ───────────────────────────────────────────────
# OPTIONAL. HTTP Event Bus for cross-service communication.
# Use Kong gateway (http://localhost:8000) or direct (http://localhost:8081)
EVENT_BUS_URL=http://localhost:8000
# API key for Kong gateway JWT authentication
EVENT_BUS_API_KEY=your-event-bus-api-key
# Default tenant for multi-tenancy
DEFAULT_TENANT_ID=apex-default


# ── LLM ─────────────────────────────────────────────────────────────────────────
# REQUIRED for memory embeddings.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OPTIONAL. Some agent runtimes still support OpenAI during the wider provider migration.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── Observability (Langfuse) ───────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=

# REQUIRED. Generate with: openssl rand -hex 16
LANGFUSE_SALT=

# REQUIRED. Generate with: echo "pk-lf-$(openssl rand -hex 16)"
LANGFUSE_PUBLIC_KEY=pk-lf-

# REQUIRED. Generate with: echo "sk-lf-$(openssl rand -hex 32)"
LANGFUSE_SECRET_KEY=sk-lf-

# REQUIRED. Password for the Langfuse admin account at http://localhost:3001
LANGFUSE_ADMIN_PASSWORD=changeme-admin

# OPTIONAL. Email for the Langfuse admin account.
LANGFUSE_ADMIN_EMAIL=admin@apex.local

# Used by apex-agents to send traces to Langfuse.
# Set to http://langfuse:3000 when running in Docker (service-to-service).
# Set to http://localhost:3001 when running apex-agents locally outside Docker.
LANGFUSE_HOST=http://langfuse:3000


# ── Integrations (apex-mcp) ───────────────────────────────────────────────────
# All OPTIONAL. Leave blank to disable.
# Tools with missing env vars return a clear 503 error, not a silent failure.

# HubSpot CRM
# Get from: https://app.hubspot.com → Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=

# Notion
# Get from: https://www.notion.so/my-integrations → New Integration
NOTION_TOKEN=

# Slack Bot Token
# Get from: https://api.slack.com/apps → your app → OAuth & Permissions → Bot Token
SLACK_BOT_TOKEN=

# Stripe (read-only access — use test key during development)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Brave Search API
# Get from: https://api.search.brave.com/register
BRAVE_SEARCH_API_KEY=

# Zapier outbound webhooks
# Base URL is the same for all Zaps.
# Add one ZAPIER_WEBHOOK_{NAME} entry per Zap you want to trigger.
# Example: ZAPIER_WEBHOOK_CRM_UPDATE=your_catch_hook_id
# Agents trigger with: call_tool("zapier_trigger", {"zap_name": "crm_update", ...})
ZAPIER_WEBHOOK_BASE_URL=https://hooks.zapier.com/hooks/catch
# ZAPIER_WEBHOOK_CRM_UPDATE=
# ZAPIER_WEBHOOK_EMAIL_ALERT=
# ZAPIER_WEBHOOK_SLACK_NOTIFY=

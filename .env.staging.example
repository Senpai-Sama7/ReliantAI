# ReliantAI Platform - Staging Environment Configuration
# Copy this file to .env for staging deployment

# Environment
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO

# Core Service URLs (Internal Docker network)
MONEY_URL=http://money:8000
COMPLIANCEONE_URL=http://complianceone:8001
FINOPS360_URL=http://finops360:8002
ORCHESTRATOR_URL=http://orchestrator:9000
INTEGRATION_URL=http://integration:8080

# Public URLs (for external access)
PUBLIC_MONEY_URL=https://staging.reliantai.io/api/money
PUBLIC_COMPLIANCEONE_URL=https://staging.reliantai.io/api/compliance
PUBLIC_FINOPS360_URL=https://staging.reliantai.io/api/finops
PUBLIC_ORCHESTRATOR_URL=https://staging.reliantai.io/api/orchestrator

# API Keys (Use strong, unique keys for staging)
DISPATCH_API_KEY=staging-dispatch-key-change-me
COMPLIANCEONE_API_KEY=staging-compliance-key-change-me
FINOPS360_API_KEY=staging-finops-key-change-me
ORCHESTRATOR_API_KEY=staging-orchestrator-key-change-me

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging-postgres-password-change-me
POSTGRES_DB=reliantai
DATABASE_URL=postgresql://postgres:staging-postgres-password-change-me@postgres:5432/reliantai

# Redis
REDIS_URL=redis://redis:6379/0

# External Services (Staging credentials)
GEMINI_API_KEY=your-staging-gemini-key
TWILIO_SID=your-staging-twilio-sid
TWILIO_TOKEN=your-staging-twilio-token
STRIPE_SECRET_KEY=sk_test_staging_key
STRIPE_WEBHOOK_SECRET=whsec_staging_secret

# Security
SECRET_KEY=staging-secret-key-change-me-min-32-chars
JWT_SECRET=staging-jwt-secret-change-me
ENCRYPTION_KEY=staging-encryption-key-change-me

# SSL/TLS
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ALERTING_ENABLED=true

# Backup
S3_BUCKET=staging-reliantai-backups
BACKUP_RETENTION_DAYS=7

# Feature Flags
AUTO_SCALING_ENABLED=true
AUTO_HEALING_ENABLED=true
AI_PREDICTIONS_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=https://staging.reliantai.io,https://app.staging.reliantai.io

# Logging
LOG_FORMAT=json
LOG_DESTINATION=stdout

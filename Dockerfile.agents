# ReliantAI Agents CLI — Autonomous 24/7 Agent System
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY pyproject.toml setup.cfg ./
RUN pip install --no-cache-dir -e ".[dev]"

# Copy application code
COPY reliantai/ ./reliantai/

# Create data directory for agent memory
RUN mkdir -p /home/agent/.local/share/reliantai
ENV AGENTS_MEMORY_DB=/home/agent/.local/share/reliantai/agents/memory.db

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

# Run the agent daemon
ENTRYPOINT ["python", "-m", "reliantai.agents.cli"]
CMD ["start", "--foreground"]

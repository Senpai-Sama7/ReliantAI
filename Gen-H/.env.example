# GEN-H Studio Environment Configuration

# API Configuration
# URL of the main HVAC dispatch API backend
VITE_API_BASE_URL=http://localhost:8000

# Optional: Admin user identifier (for display purposes)
VITE_ADMIN_USER=admin

# Optional: Disable admin features by setting to 'false'
# VITE_ENABLE_ADMIN=true

# Note: API keys are entered by the user in the admin login form
# and stored in localStorage. The backend validates against DISPATCH_API_KEY.

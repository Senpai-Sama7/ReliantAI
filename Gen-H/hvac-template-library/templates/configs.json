{
  "template_1": {
    "name": "Technical Elegance",
    "id": "template-1-technical-elegance",
    "framework": "technical-elegance",
    "description": "Split layout design for high-end HVAC with 3D viewer and technical specifications",
    "colors": {
      "primary": "#0f172a",
      "secondary": "#b87333",
      "accent": "#ff6b00",
      "neutral_light": "#f5f5f5",
      "neutral_dark": "#1a1a1a"
    },
    "typography": {
      "headline": "Playfair Display",
      "body": "Inter",
      "sizes": {
        "h1": "72px",
        "h2": "48px",
        "h3": "32px",
        "body": "16px",
        "small": "14px"
      }
    },
    "features": {
      "3d_viewer": true,
      "before_after_slider": true,
      "interactive_calculator": true,
      "service_map": true,
      "testimonials": true,
      "case_studies": true
    },
    "sections": [
      {
        "name": "Hero",
        "component": "Hero3DViewer",
        "customizable": [
          "headline",
          "subheading",
          "image"
        ]
      },
      {
        "name": "Features",
        "component": "AsymmetricalGrid",
        "customizable": [
          "cards",
          "icons",
          "colors"
        ]
      },
      {
        "name": "Services",
        "component": "SplitLayout",
        "customizable": [
          "content",
          "images"
        ]
      },
      {
        "name": "Calculator",
        "component": "InteractiveCalculator",
        "customizable": [
          "terms",
          "colors"
        ]
      },
      {
        "name": "CaseStudies",
        "component": "Portfolio",
        "customizable": [
          "items",
          "images"
        ]
      },
      {
        "name": "Testimonials",
        "component": "Carousel",
        "customizable": [
          "testimonials",
          "layout"
        ]
      },
      {
        "name": "CTA",
        "component": "CallToAction",
        "customizable": [
          "headline",
          "button_text",
          "link"
        ]
      }
    ],
    "deployment_checklist": [
      "Setup domain DNS",
      "Configure custom colors",
      "Upload company logo",
      "Add team photos",
      "Configure service areas",
      "Set up analytics",
      "Test mobile responsiveness",
      "Deploy to Vercel/Netlify"
    ]
  },

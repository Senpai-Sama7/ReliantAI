# ─────────────────────────────────────────────────────────────────────────────
# § 1  ENUMERATIONS & CONSTANTS
# ─────────────────────────────────────────────────────────────────────────────

class TaskStatus(Enum):
    PENDING     = "pending"
    READY       = "ready"       # dependencies satisfied, awaiting worker slot
    IN_PROGRESS = "in_progress"
    COMPLETED   = "completed"
    FAILED      = "failed"      # retries exhausted
    CANCELLED   = "cancelled"
    TIMED_OUT   = "timed_out"
    DEAD_LETTER = "dead_letter"  # routed to DLQ; no further processing

class CircuitState(Enum):
    CLOSED    = auto()   # normal — requests pass through
    OPEN      = auto()   # tripped — requests fail fast
    HALF_OPEN = auto()   # probe — one trial request allowed

class EventType(Enum):
    TASK_CREATED    = "task.created"
    TASK_STARTED    = "task.started"
    TASK_COMPLETED  = "task.completed"
    TASK_FAILED     = "task.failed"
    TASK_RETRYING   = "task.retrying"
    TASK_CANCELLED  = "task.cancelled"
    TASK_TIMED_OUT  = "task.timed_out"
    TASK_DLQ        = "task.dead_letter"
    CIRCUIT_TRIPPED = "circuit.tripped"
    CIRCUIT_RESET   = "circuit.reset"
    ORCHESTRATOR_STARTED = "orchestrator.started"
    ORCHESTRATOR_STOPPED = "orchestrator.stopped"

# Jitter algorithm constants (AWS full-jitter: sleep = rand(0, min(cap, base * 2^attempt)))
_BACKOFF_BASE_S: float = 0.25
_BACKOFF_CAP_S:  float = 30.0

# Circuit breaker defaults
_CB_FAILURE_THRESHOLD: int   = 5     # trips after N consecutive failures
_CB_RECOVERY_TIMEOUT_S: float = 60.0  # OPEN → HALF_OPEN probe interval
_CB_HALF_OPEN_SUCCESSES: int  = 2     # successes in HALF_OPEN before CLOSED

# ─────────────────────────────────────────────────────────────────────────────
# § 2  DATA MODELS
# ─────────────────────────────────────────────────────────────────────────────

@dataclass
class Task:
    id:           str
    type:         str                   # executor lookup key (e.g. "analyze", "deploy")
    description:  str
    payload:      Dict[str, Any]        # arbitrary task-specific input data
    status:       TaskStatus
    dependencies: List[str]             # list of task IDs that must be COMPLETED first
    priority:     int                   # lower integer = higher priority (min-heap)
    timeout_s:    float                 # seconds before asyncio.wait_for raises TimeoutError
    max_retries:  int
    retry_count:  int          = 0
    created_at:   float        = field(default_factory=time.time)
    started_at:   Optional[float]  = None
    completed_at: Optional[float]  = None
    error_message: Optional[str]   = None
    trace_id:     str          = field(default_factory=lambda: str(uuid.uuid4()))
    workflow_id:  Optional[str] = None  # groups tasks into a logical workflow

    # Min-heap ordering: lower priority int → higher scheduling precedence
    def __lt__(self, other: "Task") -> bool:
        return self.priority < other.priority

    def duration_s(self) -> Optional[float]:
        if self.started_at and self.completed_at:
            return self.completed_at - self.started_at
        return None

    def to_dict(self) -> Dict[str, Any]:
        d = asdict(self)
        d["status"] = self.status.value
        return d

    @classmethod
    def from_dict(cls, d: Dict[str, Any]) -> "Task":
        d = dict(d)
        d["status"] = TaskStatus(d["status"])
        return cls(**d)


@dataclass
class DeadLetterRecord:
    task:         Task
    routed_at:    float = field(default_factory=time.time)
    final_error:  str   = ""
    retry_history: List[Tuple[float, str]] = field(default_factory=list)


@dataclass
class CircuitBreaker:
    """
    Per-task-type circuit breaker implementing the standard three-state machine.

    State transitions:
      CLOSED  →  OPEN       : consecutive_failures >= threshold
      OPEN    →  HALF_OPEN  : recovery_timeout elapsed since tripped_at
      HALF_OPEN → CLOSED    : probe_successes >= required
      HALF_OPEN → OPEN      : any failure resets to OPEN
    """
    task_type:          str
    failure_threshold:  int   = _CB_FAILURE_THRESHOLD
    recovery_timeout_s: float = _CB_RECOVERY_TIMEOUT_S
    half_open_required: int   = _CB_HALF_OPEN_SUCCESSES

    state:               CircuitState = field(default=CircuitState.CLOSED)
    consecutive_failures: int         = 0
    probe_successes:      int         = 0
    tripped_at:          Optional[float] = None
    last_success_at:     Optional[float] = None

    def is_open(self) -> bool:
        """Returns True if a request should be fast-failed (circuit OPEN)."""
        now = time.time()
        if self.state == CircuitState.OPEN:
            if self.tripped_at and (now - self.tripped_at) >= self.recovery_timeout_s:
                # Transition to HALF_OPEN to allow a probe
                self.state = CircuitState.HALF_OPEN
                self.probe_successes = 0
                return False  # allow probe through
            return True  # still blocking
        return False

    def record_success(self) -> None:
        self.last_success_at = time.time()
        if self.state == CircuitState.HALF_OPEN:
            self.probe_successes += 1
            if self.probe_successes >= self.half_open_required:
                self.state = CircuitState.CLOSED
                self.consecutive_failures = 0
                self.probe_successes = 0
        elif self.state == CircuitState.CLOSED:
            self.consecutive_failures = 0

    def record_failure(self) -> bool:
        """Returns True if the circuit just tripped (CLOSED→OPEN transition)."""
        self.consecutive_failures += 1
        if self.state == CircuitState.HALF_OPEN:
            # Any failure in probe sends us back to OPEN
            self.state = CircuitState.OPEN
            self.tripped_at = time.time()
            return True
        if self.state == CircuitState.CLOSED and self.consecutive_failures >= self.failure_threshold:
            self.state = CircuitState.OPEN
            self.tripped_at = time.time()
            return True
        return False



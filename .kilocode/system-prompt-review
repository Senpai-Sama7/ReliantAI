class StructuredLogger:
    """
    Emits newline-delimited JSON log records for machine ingestion
    while also providing a human-readable console formatter in dev mode.

    Every record carries:
      ts          – Unix epoch with millisecond precision
      level       – DEBUG / INFO / WARNING / ERROR / CRITICAL
      service     – constant service identifier
      event       – machine-parseable event key
      trace_id    – per-task correlation identifier (propagated from Task.trace_id)
      context     – arbitrary structured payload dict
    """

    def __init__(self, service: str = "orchestrator", dev_mode: bool = True):
        self.service   = service
        self.dev_mode  = dev_mode
        self._logger   = logging.getLogger(service)
        self._logger.setLevel(logging.DEBUG)

        if not self._logger.handlers:
            handler = logging.StreamHandler()
            if dev_mode:
                # Human-friendly for development
                handler.setFormatter(
                    logging.Formatter("%(asctime)s  %(levelname)-8s  %(message)s",
                                      datefmt="%H:%M:%S")
                )
            else:
                # Raw JSON for production log aggregators (Loki, CloudWatch, etc.)
                handler.setFormatter(logging.Formatter("%(message)s"))
            self._logger.addHandler(handler)

        # Append-only JSON audit log to disk
        self._audit_path = pathlib.Path("orchestrator_audit.jsonl")
        self._audit_fh   = self._audit_path.open("a", encoding="utf-8")

    def _emit(self, level: str, event: str, trace_id: str = "",
              context: Optional[Dict[str, Any]] = None) -> None:
        record = {
            "ts":        time.time(),
            "level":     level,
            "service":   self.service,
            "event":     event,
            "trace_id":  trace_id,
            "context":   context or {},
        }
        line = json.dumps(record, default=str)
        # Persist to audit log (never sampled — all events)
        self._audit_fh.write(line + "\n")
        self._audit_fh.flush()

        # Console output
        if self.dev_mode:
            ctx_str = "  " + json.dumps(context, default=str) if context else ""
            msg = f"[{event}]{ctx_str}" + (f"  trace={trace_id[:8]}" if trace_id else "")
        else:
            msg = line

        getattr(self._logger, level.lower(), self._logger.info)(msg)

    def info(self, event: str, trace_id: str = "", **ctx: Any) -> None:
        self._emit("INFO", event, trace_id, ctx)

    def warning(self, event: str, trace_id: str = "", **ctx: Any) -> None:
        self._emit("WARNING", event, trace_id, ctx)

    def error(self, event: str, trace_id: str = "", **ctx: Any) -> None:
        self._emit("ERROR", event, trace_id, ctx)

    def debug(self, event: str, trace_id: str = "", **ctx: Any) -> None:
        self._emit("DEBUG", event, trace_id, ctx)

    def close(self) -> None:
        self._audit_fh.close()



async def demo() -> None:
    """
    Demonstrates the full orchestrator feature set.
    Remove this function and replace with your own entrypoint when integrating.
    """

    orch = Orchestrator(
        max_concurrent = 4,
        db_path        = "demo_orchestrator.db",
        health_port    = 8787,   # set to None to disable HTTP health server
        dev_mode       = True,
    )

    # ── Subscribe to lifecycle events ─────────────────────────────────────
    async def on_completed(event: Event) -> None:
        # Example: trigger downstream notification, webhook, etc.
        pass

    async def on_dlq(event: Event) -> None:
        print(f"⚠️  ALERT: Task {event.task_id} entered Dead Letter Queue")
        print(f"   Error: {event.data.get('error')}")

    orch._bus.subscribe(EventType.TASK_COMPLETED, on_completed)
    orch._bus.subscribe(EventType.TASK_DLQ,       on_dlq)

    # ── Register a custom executor ────────────────────────────────────────
    @orch.executors.register("send_report")
    async def send_report(ctx: OrchestratorContext, task: Task) -> Dict[str, Any]:
        recipients = task.payload.get("recipients", [])
        subject    = task.payload.get("subject",    "Report")
        ctx.log.info("executor.send_report", trace_id=task.trace_id,
                     recipients=recipients, subject=subject)
        # Replace with real email/Slack/webhook logic
        await asyncio.sleep(0)
        return {"sent_to": recipients, "subject": subject}

    # ── Submit a dependency-chained workflow ──────────────────────────────
    wf = (WorkflowBuilder("daily_pipeline")
          .task("fetch_data",    type="http_get",
                payload={"url": "https://httpbin.org/get"},
                priority=2, timeout_s=10.0)
          .task("analyze_data",  type="analyze",
                payload={"target": "fetched_data"},
                depends_on=["fetch_data"], priority=3)
          .task("generate_report", type="send_report",
                payload={"recipients": ["ops@example.com"], "subject": "Daily Report"},
                depends_on=["analyze_data"], priority=5)
          .build())

    orch.submit_workflow(wf)

    # ── Also submit standalone tasks ──────────────────────────────────────
    orch.submit("monitor_1",  type="monitor",  priority=8)
    orch.submit("monitor_2",  type="monitor",  priority=8)
    orch.submit("deploy_app", type="deploy",
                payload={"artifact": "api-service", "version": "2.1.0"},
                priority=1, timeout_s=60.0)

    # ── Run until all tasks complete (batch mode) ─────────────────────────
    await orch.run(stop_when_empty=True)

    # ── Print final state and export runbook ─────────────────────────────
    orch.print_status()
    orch.export_runbook("demo_runbook.md")
    print("\n✅ Runbook exported to demo_runbook.md")
    print(f"✅ Audit log written to orchestrator_audit.jsonl")
    print(f"✅ Database persisted to demo_orchestrator.db")


if __name__ == "__main__":
    asyncio.run(demo())
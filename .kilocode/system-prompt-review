class MetricsRegistry:
    """
    Minimal in-process metrics store.  No external dependencies.
    Tracks: counters (monotonically increasing), gauges (point-in-time),
    histograms (latency distribution via fixed power-of-two buckets).

    For production export, replace with prometheus_client or opentelemetry-sdk
    without changing call sites — this registry uses the same semantic model.
    """

    def __init__(self) -> None:
        self._counters:   Dict[str, float]       = collections.defaultdict(float)
        self._gauges:     Dict[str, float]        = collections.defaultdict(float)
        self._histograms: Dict[str, List[float]]  = collections.defaultdict(list)

    def counter_inc(self, name: str, value: float = 1.0, **labels: str) -> None:
        key = self._key(name, labels)
        self._counters[key] += value

    def gauge_set(self, name: str, value: float, **labels: str) -> None:
        key = self._key(name, labels)
        self._gauges[key] = value

    def histogram_observe(self, name: str, value: float, **labels: str) -> None:
        key = self._key(name, labels)
        self._histograms[key].append(value)

    def histogram_quantile(self, name: str, quantile: float, **labels: str) -> Optional[float]:
        key = self._key(name, labels)
        data = sorted(self._histograms.get(key, []))
        if not data:
            return None
        idx = max(0, math.ceil(quantile * len(data)) - 1)
        return data[idx]

    def snapshot(self) -> Dict[str, Any]:
        hist_summary = {}
        for k, vals in self._histograms.items():
            if vals:
                s = sorted(vals)
                hist_summary[k] = {
                    "count": len(s),
                    "sum":   sum(s),
                    "p50":   s[int(0.50 * len(s))],
                    "p95":   s[int(0.95 * len(s))],
                    "p99":   s[int(0.99 * len(s))],
                    "max":   s[-1],
                }
        return {
            "counters":   dict(self._counters),
            "gauges":     dict(self._gauges),
            "histograms": hist_summary,
        }

    @staticmethod
    def _key(name: str, labels: Dict[str, str]) -> str:
        if not labels:
            return name
        label_str = ",".join(f'{k}="{v}"' for k, v in sorted(labels.items()))
        return f"{name}{{{label_str}}}"


# ─────────────────────────────────────────────────────────────────────────────
# § 5  PERSISTENCE LAYER  (SQLite + WAL)
# ─────────────────────────────────────────────────────────────────────────────

class TaskStore:
    """
    SQLite-backed persistence using WAL (Write-Ahead Log) journal mode.

    WAL vs. DELETE journal mode:
      DELETE (default): Writer blocks all readers; single-writer model.
      WAL:              Readers never block writers; writers never block readers.
                        Dramatically reduces contention under concurrent reads.

    Schema design:
      tasks       — canonical task state
      dlq         — dead letter records (immutable once inserted)
      events      — immutable append-only event audit trail (separate from logs)

    All writes are wrapped in explicit transactions; read operations use
    isolation_level=None (autocommit) for read consistency without locks.
    """

    def __init__(self, db_path: str = "orchestrator.db") -> None:
        self.db_path = db_path
        self._conn   = sqlite3.connect(db_path, check_same_thread=False,
                                       isolation_level=None)
        self._conn.execute("PRAGMA journal_mode=WAL")
        self._conn.execute("PRAGMA synchronous=NORMAL")  # fsync on checkpoint, not every write
        self._conn.execute("PRAGMA foreign_keys=ON")
        self._conn.execute("PRAGMA cache_size=-32000")   # 32 MB page cache
        self._bootstrap()

    def _bootstrap(self) -> None:
        with self._conn:
            self._conn.executescript("""
                CREATE TABLE IF NOT EXISTS tasks (
                    id           TEXT PRIMARY KEY,
                    type         TEXT NOT NULL,
                    description  TEXT NOT NULL,
                    payload      TEXT NOT NULL DEFAULT '{}',
                    status       TEXT NOT NULL,
                    dependencies TEXT NOT NULL DEFAULT '[]',
                    priority     INTEGER NOT NULL DEFAULT 5,
                    timeout_s    REAL NOT NULL DEFAULT 30.0,
                    max_retries  INTEGER NOT NULL DEFAULT 3,
                    retry_count  INTEGER NOT NULL DEFAULT 0,
                    created_at   REAL NOT NULL,
                    started_at   REAL,
                    completed_at REAL,
                    error_message TEXT,
                    trace_id     TEXT NOT NULL,
                    workflow_id  TEXT
                );

                CREATE INDEX IF NOT EXISTS idx_tasks_status   ON tasks(status);
                CREATE INDEX IF NOT EXISTS idx_tasks_workflow  ON tasks(workflow_id);
                CREATE INDEX IF NOT EXISTS idx_tasks_priority  ON tasks(priority);

                CREATE TABLE IF NOT EXISTS dlq (
                    id           TEXT PRIMARY KEY,
                    task_json    TEXT NOT NULL,
                    routed_at    REAL NOT NULL,
                    final_error  TEXT NOT NULL,
                    retry_history TEXT NOT NULL DEFAULT '[]'
                );

                CREATE TABLE IF NOT EXISTS events (
                    seq          INTEGER PRIMARY KEY AUTOINCREMENT,
                    event_type   TEXT NOT NULL,
                    task_id      TEXT,
                    trace_id     TEXT,
                    ts           REAL NOT NULL,
                    payload      TEXT NOT NULL DEFAULT '{}'
                );
                CREATE INDEX IF NOT EXISTS idx_events_task ON events(task_id);
            """)

    # ── Task CRUD ──────────────────────────────────────────────────────────

    def upsert_task(self, task: Task) -> None:
        with self._conn:
            self._conn.execute("""
                INSERT INTO tasks VALUES (
                    :id, :type, :description, :payload, :status, :dependencies,
                    :priority, :timeout_s, :max_retries, :retry_count,
                    :created_at, :started_at, :completed_at, :error_message,
                    :trace_id, :workflow_id
                ) ON CONFLICT(id) DO UPDATE SET
                    status        = excluded.status,
                    retry_count   = excluded.retry_count,
                    started_at    = excluded.started_at,
                    completed_at  = excluded.completed_at,
                    error_message = excluded.error_message
            """, {
                "id":           task.id,
                "type":         task.type,
                "description":  task.description,
                "payload":      json.dumps(task.payload),
                "status":       task.status.value,
                "dependencies": json.dumps(task.dependencies),
                "priority":     task.priority,
                "timeout_s":    task.timeout_s,
                "max_retries":  task.max_retries,
                "retry_count":  task.retry_count,
                "created_at":   task.created_at,
                "started_at":   task.started_at,
                "completed_at": task.completed_at,
                "error_message": task.error_message,
                "trace_id":     task.trace_id,
                "workflow_id":  task.workflow_id,
            })

    def load_all(self) -> List[Task]:
        rows = self._conn.execute("SELECT * FROM tasks").fetchall()
        cols = [d[0] for d in self._conn.execute("SELECT * FROM tasks LIMIT 0").description or []]
        if not rows:
            return []
        result = []
        for row in rows:
            d = dict(zip(cols, row))
            d["payload"]      = json.loads(d["payload"])
            d["dependencies"] = json.loads(d["dependencies"])
            d["status"]       = TaskStatus(d["status"])
            result.append(Task(**d))
        return result

    def load_incomplete(self) -> List[Task]:
        """On restart, recover tasks that were in-flight or pending."""
        rows = self._conn.execute(
            "SELECT * FROM tasks WHERE status IN ('pending','ready','in_progress')"
        ).fetchall()
        if not rows:
            return []
        cols = [d[0] for d in self._conn.execute(
            "SELECT * FROM tasks LIMIT 0").description or []]
        result = []
        for row in rows:
            d = dict(zip(cols, row))
            d["payload"]      = json.loads(d["payload"])
            d["dependencies"] = json.loads(d["dependencies"])
            d["status"]       = TaskStatus(d["status"])
            # Tasks that were IN_PROGRESS at crash time revert to PENDING
            if d["status"] == TaskStatus.IN_PROGRESS:
                d["status"] = TaskStatus.PENDING
                d["started_at"] = None
            result.append(Task(**d))
        return result

    # ── DLQ ──────────────────────────────────────────────────────────────

    def insert_dlq(self, record: DeadLetterRecord) -> None:
        with self._conn:
            self._conn.execute("""
                INSERT OR IGNORE INTO dlq VALUES (?, ?, ?, ?, ?)
            """, (
                record.task.id,
                json.dumps(record.task.to_dict()),
                record.routed_at,
                record.final_error,
                json.dumps(record.retry_history),
            ))

    def load_dlq(self) -> List[DeadLetterRecord]:
        rows = self._conn.execute("SELECT * FROM dlq").fetchall()
        return [
            DeadLetterRecord(
                task=Task.from_dict(json.loads(r[1])),
                routed_at=r[2],
                final_error=r[3],
                retry_history=json.loads(r[4]),
            )
            for r in rows
        ]

    # ── Event log ────────────────────────────────────────────────────────

    def append_event(self, event_type: EventType, task_id: str = "",
                     trace_id: str = "", payload: Optional[Dict] = None) -> None:
        with self._conn:
            self._conn.execute(
                "INSERT INTO events(event_type, task_id, trace_id, ts, payload) VALUES (?,?,?,?,?)",
                (event_type.value, task_id, trace_id, time.time(),
                 json.dumps(payload or {}))
            )

    def close(self) -> None:
        self._conn.close()



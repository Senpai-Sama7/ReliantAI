# § 7  EXECUTOR REGISTRY  (Plugin system)
# ─────────────────────────────────────────────────────────────────────────────

ExecutorFn = Callable[["OrchestratorContext", Task], Awaitable[Dict[str, Any]]]

class ExecutorRegistry:
    """
    Maps task.type strings to async callable executors.

    Registration:
        registry.register("scrape_url")(async def executor(ctx, task): ...)

    The registry is the seam between the orchestration engine (this file)
    and your application business logic (your code).  Executors receive
    an OrchestratorContext giving them access to the task store, metrics,
    event bus, and a logger — they return a dict of output data.
    """

    def __init__(self) -> None:
        self._executors: Dict[str, ExecutorFn] = {}
        self._fallback:  Optional[ExecutorFn]  = None

    def register(self, task_type: str) -> Callable[[ExecutorFn], ExecutorFn]:
        def decorator(fn: ExecutorFn) -> ExecutorFn:
            self._executors[task_type] = fn
            return fn
        return decorator

    def set_fallback(self, fn: ExecutorFn) -> None:
        """Fallback executor called when no type-specific handler is registered."""
        self._fallback = fn

    def get(self, task_type: str) -> Optional[ExecutorFn]:
        return self._executors.get(task_type) or self._fallback

    def registered_types(self) -> List[str]:
        return list(self._executors.keys())



@dataclass
class Event:
    type:     EventType
    task_id:  str
    trace_id: str
    ts:       float = field(default_factory=time.time)
    data:     Dict[str, Any] = field(default_factory=dict)


HandlerFn = Callable[[Event], Awaitable[None]]


class EventBus:
    """
    Async pub/sub event bus.

    Subscribers register per-EventType (or wildcard "*") async callables.
    Events are dispatched non-blockingly via asyncio.Queue — the publisher
    never awaits handler completion, preventing slow consumers from stalling
    the orchestrator's hot path.

    Delivery guarantee: at-least-once within a single process lifetime.
    No durability across restarts (use TaskStore.events for that).
    """

    def __init__(self) -> None:
        self._handlers: Dict[str, List[HandlerFn]] = collections.defaultdict(list)
        self._queue:    asyncio.Queue[Event]        = asyncio.Queue()
        self._running   = False
        self._task:     Optional[asyncio.Task]      = None

    def subscribe(self, event_type: EventType | str, handler: HandlerFn) -> None:
        key = event_type.value if isinstance(event_type, EventType) else event_type
        self._handlers[key].append(handler)

    def publish(self, event: Event) -> None:
        """Non-blocking publish — safe to call from sync or async context."""
        try:
            self._queue.put_nowait(event)
        except asyncio.QueueFull:
            pass  # drop under extreme backpressure; structured log captures source truth

    async def _dispatch_loop(self) -> None:
        while self._running:
            try:
                event = await asyncio.wait_for(self._queue.get(), timeout=1.0)
            except asyncio.TimeoutError:
                continue
            handlers = self._handlers.get(event.type.value, []) + \
                       self._handlers.get("*", [])
            for h in handlers:
                asyncio.create_task(self._safe_call(h, event))

    @staticmethod
    async def _safe_call(handler: HandlerFn, event: Event) -> None:
        with contextlib.suppress(Exception):
            await handler(event)

    async def start(self) -> None:
        self._running = True
        self._task    = asyncio.create_task(self._dispatch_loop())

    async def stop(self) -> None:
        self._running = False
        if self._task:
            await asyncio.gather(self._task, return_exceptions=True)


